{
  "name": "@diagram-tour/web-player",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./build/index.js",
  "exports": {
    ".": "./build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "svelte-kit sync && vite build",
    "preview": "node build",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "svelte-kit sync && vitest run --config ./vitest.config.ts --coverage",
    "smoke": "bun run smoke:core",
    "smoke:core": "playwright test --config ./playwright.config.ts --grep @core",
    "smoke:extended": "playwright test --config ./playwright.config.ts --grep @extended --workers 2",
    "smoke:full": "playwright test --config ./playwright.config.ts --workers 2",
    "lint": "eslint . --max-warnings 0 && stylelint \"src/styles/**/*.css\" --max-warnings 0"
  },
  "dependencies": {
    "@diagram-tour/core": "workspace:*",
    "@diagram-tour/parser": "workspace:*",
    "mermaid": "^11.12.0",
    "svelte-sonner": "^0.3.28"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2",
    "@sveltejs/adapter-node": "5.3.2",
    "@sveltejs/kit": "2.53.4",
    "@testing-library/svelte": "^5.2.8",
    "jsdom": "^26.1.0",
    "svelte": "5.53.10",
    "svelte-check": "4.4.5",
    "stylelint": "^16.24.0",
    "stylelint-config-standard": "^39.0.1",
    "vite": "7.3.1"
  }
}
