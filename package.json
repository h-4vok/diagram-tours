{
  "name": "diagram-tour",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo scaffold for guided tours over Mermaid diagrams.",
  "license": "MIT",
  "packageManager": "bun@1.2.19",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --cwd packages/core build && bun run --cwd packages/parser build && bun run --cwd packages/web-player build",
    "test": "bun run --filter '*' test",
    "dev": "bun run --cwd packages/web-player dev",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "bun run --filter '*' lint",
    "lint:fix": "eslint . --fix",
    "prepush": "bun run lint && bun run typecheck && bun run test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "eslint": "^9.23.0",
    "eslint-plugin-svelte": "^3.11.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "svelte-eslint-parser": "^1.1.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.28.0"
  }
}
